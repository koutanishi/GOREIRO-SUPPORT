  </div>

  <!-- Flow -->
  <div class="flow">
    <div class="section-label">How to Start</div>
    <div class="flow-steps">
      <div class="flow-step">
        <div class="flow-num">01</div>
        <div class="flow-title">申し込み</div>
        <div class="flow-desc">下のボタンからフォームへ</div>
      </div>
      <div class="flow-step">
        <div class="flow-num">02</div>
        <div class="flow-title">ZOOMで話す</div>
